# --- evarkadasi.com ortam değişkenleri ---

# Yönetici (moderasyon) paneline erişim anahtarı.
# /admin?key=BU_DEGER ile ilanları silebilirsiniz. UZUN ve GİZLİ tutun.
ADMIN_KEY=degistir-bu-cok-gizli-bir-anahtar

# IP hashleme ve captcha imzalama için gizli anahtar.
# Rastgele, uzun bir değer girin (örn. `openssl rand -hex 32`).
APP_SECRET=degistir-rastgele-uzun-bir-secret-32-bayt

# İlanların kaç gün sonra otomatik silineceği (varsayılan 30).
LISTING_TTL_DAYS=30

# --- Veritabanı (Turso / libSQL) ---
# YERELDE: bu ikisini BOŞ bırakın; otomatik olarak data/evarkadasi.db dosyası kullanılır.
# VERCEL / CANLI: Turso'dan aldığınız değerleri girin.
#   turso db create evarkadasi
#   turso db show evarkadasi --url      ->  TURSO_DATABASE_URL
#   turso db tokens create evarkadasi   ->  TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
